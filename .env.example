# Copy this file to .env (in the same directory as docker-compose.yml).
# docker-compose reads .env automatically.
#
# DB_* and REDIS_* here override the values in backend/.env so that
# all services (mysql container + backend container) use the same credentials.

# ── MySQL / Backend DB ────────────────────────────────────────────────────
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=everyday_card

# ── API keys (these are also in backend/.env – only needed here if you
#    want to avoid editing backend/.env directly) ─────────────────────────
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# FIRECRAWL_API_TOKEN=
